GOZZLE_CLICKHOUSE_URL=http://localhost:8123
GOZZLE_CLICKHOUSE_USER=default
GOZZLE_CLICKHOUSE_PASSWORD=
GOZZLE_CLICKHOUSE_DATABASE=default

# Safety harness (optional; defaults shown). See the docs for details.
# GOZZLE_ENFORCE_READONLY=true     # force readonly=2 on every query
# GOZZLE_MAX_EXECUTION_TIME=30     # seconds; 0 disables
# GOZZLE_MAX_RESULT_ROWS=10000     # rows returned to Gozzle; 0 disables
# GOZZLE_MAX_ROWS_TO_READ=0        # abort over-large scans; 0 disables
# GOZZLE_MAX_BYTES_TO_READ=0       # abort over-large scans; 0 disables
# GOZZLE_AUDIT_LOG=                # path to append a JSON-lines audit log

# Faithful local slices (optional; defaults shown).
# GOZZLE_SLICE_DIR=~/.gozzle/slices
# GOZZLE_MAX_SLICE_ROWS=100000      # complete partitions only
# GOZZLE_MAX_SLICE_BYTES=268435456  # 256 MiB source bytes on disk
# GOZZLE_MAX_TOTAL_SLICE_BYTES=2147483648 # 2 GiB across all workspaces
