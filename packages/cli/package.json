{
  "name": "@gozzle/cli",
  "version": "0.0.1-canary.0",
  "description": "A local safety harness and developer toolkit for ClickHouse.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "bin": {
    "gozzle": "./dist/src/cli.js",
    "gozzle-mcp": "./dist/src/mcp/server.js"
  },
  "files": [
    "dist/src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "canary"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev:mcp": "tsx src/mcp/server.ts",
    "dev": "tsx src/cli.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build && npm test",
    "smoke:mcp": "npm run build && node dist/scripts/mcp-smoke.js",
    "test": "node --import tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@clickhouse/client": "^1.21.0",
    "@modelcontextprotocol/sdk": "^1.18.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=22"
  }
}
