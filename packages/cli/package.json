{
  "name": "@gozzle/cli",
  "version": "0.1.7",
  "description": "Agent verification layer for ClickHouse changes.",
  "type": "module",
  "private": false,
  "license": "Apache-2.0",
  "author": "Luke Reilly",
  "homepage": "https://github.com/lureilly1/gozzle#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lureilly1/gozzle.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/lureilly1/gozzle/issues"
  },
  "keywords": [
    "clickhouse",
    "mcp",
    "model-context-protocol",
    "sql",
    "migration",
    "deduplication",
    "read-only",
    "cli",
    "ai-agents",
    "database"
  ],
  "bin": {
    "gozzle": "./dist/src/cli.js",
    "gozzle-mcp": "./dist/src/mcp/server.js"
  },
  "files": [
    "dist/src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev:mcp": "tsx src/mcp/server.ts",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build && npm test",
    "smoke:mcp": "npm run build && node dist/scripts/mcp-smoke.js",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:integration": "node --import tsx --test tests/integration/*.test.ts"
  },
  "dependencies": {
    "@clickhouse/client": "^1.21.0",
    "@modelcontextprotocol/sdk": "^1.18.0",
    "yaml": "^2.9.0",
    "zod": "^4.0.0"
  },
  "optionalDependencies": {
    "chdb": "^2.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=22"
  }
}
