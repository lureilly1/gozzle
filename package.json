{
  "name": "gozzle-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for gozzle — a local safety harness and developer toolkit for ClickHouse.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lureilly1/gozzle.git"
  },
  "bugs": {
    "url": "https://github.com/lureilly1/gozzle/issues"
  },
  "homepage": "https://github.com/lureilly1/gozzle#readme",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:cli": "npm run build -w @gozzle/cli",
    "build:web": "npm run build -w @gozzle/web",
    "dev:web": "npm run dev -w @gozzle/web",
    "test": "npm run test -w @gozzle/cli",
    "lint": "eslint \"packages/cli/**/*.ts\"",
    "format": "prettier --write \"packages/cli/{src,tests,scripts}/**/*.ts\"",
    "format:check": "prettier --check \"packages/cli/{src,tests,scripts}/**/*.ts\""
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.62.0"
  }
}
